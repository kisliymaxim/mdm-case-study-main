APP_NAME=WorkWize-MDM
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=mdm
DB_USERNAME=mdm
DB_PASSWORD=mdm

SESSION_DRIVER=array
SESSION_LIFETIME=120

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# Reverb (WebSocket server, Pusher protocol) — used for live sync progress.
REVERB_APP_ID=603204
REVERB_APP_KEY=92c66ec4ea0273b11ffa
REVERB_APP_SECRET=b0590f9869ba2e39a945581ce3ea7818f116a18e
REVERB_HOST=localhost
REVERB_PORT=8081
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8081

# Queue + cache live in Redis. The "queue" container runs `queue:work redis`.
# Failed-jobs driver is `null` (no DB persistence) because we deliberately
# don't carry a `failed_jobs` table — Redis is the queue, and our job has
# tries=1 so persistent failure history isn't useful here.
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=null
CACHE_STORE=redis
# CACHE_PREFIX=

# CORS — Vite dev server. Both loopback hosts are listed because browsers
# treat localhost:5173 and 127.0.0.1:5173 as separate origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Redis. predis/predis is a pure-PHP client — no PECL ext-redis needed.
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
